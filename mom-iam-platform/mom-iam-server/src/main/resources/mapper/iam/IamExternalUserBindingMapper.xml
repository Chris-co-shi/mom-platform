<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.chrisshi.mom.iam.infrastructure.persistence.mapper.IamExternalUserBindingMapper">

    <select id="selectEffectiveByUserId"
            resultType="io.github.chrisshi.mom.iam.infrastructure.persistence.entity.IamExternalUserBindingEntity">
        SELECT *
          FROM iam_external_user_binding
         WHERE user_id = #{userId}
           AND status = 'ENABLED'
           AND (valid_from IS NULL OR valid_from &lt;= #{now})
           AND (valid_until IS NULL OR valid_until &gt; #{now})
    </select>
</mapper>
